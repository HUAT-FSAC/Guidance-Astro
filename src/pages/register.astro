---
export const prerender = false
import '../styles/auth.css'
---

<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>注册 — FSAC AST Docs</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <style>
        body { margin: 0; font-family: system-ui, sans-serif; background: var(--sl-color-bg); color: var(--sl-color-text); }
    </style>
</head>
<body>
    <div class="auth-container">
        <div class="auth-card">
            <h1>注册</h1>
            <div class="auth-error" id="error-msg"></div>
            <form id="register-form">
                <div class="auth-field">
                    <label for="username">用户名</label>
                    <input id="username" name="username" type="text" required autocomplete="username" />
                </div>
                <div class="auth-field">
                    <label for="email">邮箱</label>
                    <input id="email" name="email" type="email" required autocomplete="email" />
                </div>
                <div class="auth-field">
                    <label for="password">密码</label>
                    <input id="password" name="password" type="password" required autocomplete="new-password" />
                </div>
                <div class="auth-field">
                    <label for="confirmPassword">确认密码</label>
                    <input id="confirmPassword" name="confirmPassword" type="password" required autocomplete="new-password" />
                </div>
                <button type="submit" class="auth-btn auth-btn-primary">注册</button>
            </form>
            <div class="auth-link">已有账号？<a href="/login/">登录</a></div>
        </div>
    </div>
    <script>
        const form = document.getElementById('register-form') as HTMLFormElement;
        const errorEl = document.getElementById('error-msg') as HTMLDivElement;

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            errorEl.style.display = 'none';
            const username = (form.querySelector('#username') as HTMLInputElement).value;
            const email = (form.querySelector('#email') as HTMLInputElement).value;
            const password = (form.querySelector('#password') as HTMLInputElement).value;
            const confirmPassword = (form.querySelector('#confirmPassword') as HTMLInputElement).value;

            // 验证用户名：2-32位，支持字母、数字、下划线和中文
            if (!/^[a-zA-Z0-9_\u4e00-\u9fa5]{2,32}$/.test(username)) {
                errorEl.textContent = '用户名需 2-32 位，支持字母、数字、下划线和中文';
                errorEl.style.display = 'block';
                return;
            }
            if (password.length < 8) {
                errorEl.textContent = '密码至少需要 8 个字符';
                errorEl.style.display = 'block';
                return;
            }
            if (password !== confirmPassword) {
                errorEl.textContent = '两次输入的密码不一致';
                errorEl.style.display = 'block';
                return;
            }
            try {
                const res = await fetch('/api/auth/register/', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ username, email, password }),
                });
                if (res.ok) {
                    location.href = '/';
                } else {
                    const data = await res.json().catch(() => ({})) as { error?: string };
                    errorEl.textContent = data.error || '注册失败，请重试';
                    errorEl.style.display = 'block';
                }
            } catch {
                errorEl.textContent = '网络错误，请稍后重试';
                errorEl.style.display = 'block';
            }
        });
    </script>
</body>
</html>
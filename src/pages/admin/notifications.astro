---
export const prerender = false
import '../../styles/admin.css'
import { hasRole } from '../../lib/auth'
import { env } from 'cloudflare:workers'

const user = Astro.locals.user

// 检查权限
if (!user || !hasRole(user.role, 'admin')) {
    return Astro.redirect('/')
}

// 获取通知历史
const notifications = await env.DB.prepare(
    `SELECT 
        n.id, n.title, n.body, n.url, n.sent_at,
        u.username as sender_name,
        (SELECT COUNT(*) FROM push_notification_recipients WHERE notification_id = n.id AND delivered = 1) as delivered_count,
        (SELECT COUNT(*) FROM push_notification_recipients WHERE notification_id = n.id AND delivered = 0) as failed_count
    FROM push_notifications n
    LEFT JOIN users u ON n.sender_id = u.id
    ORDER BY n.sent_at DESC
    LIMIT 20`
).all<{
    id: string
    title: string
    body: string | null
    url: string | null
    sent_at: number
    sender_name: string | null
    delivered_count: number
    failed_count: number
}>()

// 获取订阅者数量
const subscriberCount = await env.DB.prepare(
    'SELECT COUNT(*) as count FROM push_subscriptions'
).first<{ count: number }>()
---

<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>推送通知管理 — FSAC AST Docs</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <style>
        body { margin: 0; font-family: system-ui, sans-serif; background: var(--sl-color-bg); color: var(--sl-color-text); }
        
        .notification-form {
            background: var(--sl-color-bg-nav);
            border: 1px solid var(--sl-color-hairline);
            border-radius: 8px;
            padding: 1.5rem;
            margin-bottom: 2rem;
        }
        
        .form-group {
            margin-bottom: 1rem;
        }
        
        .form-group label {
            display: block;
            font-size: 0.875rem;
            margin-bottom: 0.375rem;
            color: var(--sl-color-gray-3);
        }
        
        .form-group input,
        .form-group textarea {
            width: 100%;
            padding: 0.5rem 0.75rem;
            border: 1px solid var(--sl-color-hairline);
            border-radius: 6px;
            background: var(--sl-color-bg);
            color: var(--sl-color-text);
            font-size: 0.875rem;
            box-sizing: border-box;
        }
        
        .form-group input:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: var(--sl-color-accent);
        }
        
        .form-group textarea {
            min-height: 80px;
            resize: vertical;
        }
        
        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }
        
        @media (max-width: 640px) {
            .form-row {
                grid-template-columns: 1fr;
            }
        }
        
        .btn {
            padding: 0.625rem 1.25rem;
            border: none;
            border-radius: 6px;
            font-size: 0.875rem;
            cursor: pointer;
            transition: opacity 0.2s;
        }
        
        .btn:hover {
            opacity: 0.9;
        }
        
        .btn-primary {
            background: var(--sl-color-accent);
            color: white;
        }
        
        .btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }
        
        .stats-cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 1rem;
            margin-bottom: 2rem;
        }
        
        .stat-card {
            background: var(--sl-color-bg-nav);
            border: 1px solid var(--sl-color-hairline);
            border-radius: 8px;
            padding: 1rem;
            text-align: center;
        }
        
        .stat-value {
            font-size: 1.75rem;
            font-weight: 700;
            color: var(--sl-color-accent);
        }
        
        .stat-label {
            font-size: 0.8rem;
            color: var(--sl-color-gray-3);
            margin-top: 0.25rem;
        }
        
        .notification-list {
            margin-top: 1.5rem;
        }
        
        .notification-item {
            background: var(--sl-color-bg-nav);
            border: 1px solid var(--sl-color-hairline);
            border-radius: 8px;
            padding: 1rem;
            margin-bottom: 0.75rem;
        }
        
        .notification-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 0.5rem;
        }
        
        .notification-title {
            font-weight: 600;
            font-size: 1rem;
        }
        
        .notification-time {
            font-size: 0.8rem;
            color: var(--sl-color-gray-3);
        }
        
        .notification-body {
            font-size: 0.875rem;
            color: var(--sl-color-gray-2);
            margin-bottom: 0.5rem;
        }
        
        .notification-stats {
            display: flex;
            gap: 1rem;
            font-size: 0.8rem;
        }
        
        .notification-stats .success {
            color: #28a745;
        }
        
        .notification-stats .error {
            color: #dc3545;
        }
        
        .toast {
            position: fixed;
            top: 1rem;
            right: 1rem;
            padding: 0.75rem 1rem;
            border-radius: 6px;
            font-size: 0.875rem;
            z-index: 1001;
            animation: slideIn 0.3s ease;
        }
        
        .toast.success {
            background: #28a745;
            color: white;
        }
        
        .toast.error {
            background: #dc3545;
            color: white;
        }
        
        @keyframes slideIn {
            from {
                transform: translateX(100%);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }
        
        .empty-state {
            text-align: center;
            padding: 2rem;
            color: var(--sl-color-gray-3);
        }
    </style>
</head>
<body>
    <div class="admin-layout">
        <aside class="admin-sidebar">
            <h2>管理后台</h2>
            <nav>
                <a href="/admin/">仪表盘</a>
                <a href="/admin/users/">用户管理</a>
                <a href="/admin/members/">成员管理</a>
                <a href="/admin/notifications/" class="active">推送通知</a>
            </nav>
            <div style="margin-top:2rem;font-size:0.8rem;color:var(--sl-color-gray-3)">
                {user?.username} ({user?.role})
            </div>
        </aside>
        <main class="admin-main">
            <h1>推送通知管理</h1>
            
            <!-- 统计卡片 -->
            <div class="stats-cards">
                <div class="stat-card">
                    <div class="stat-value">{subscriberCount?.count || 0}</div>
                    <div class="stat-label">订阅用户</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">{notifications.results.length}</div>
                    <div class="stat-label">已发送通知</div>
                </div>
            </div>
            
            <!-- 发送表单 -->
            <div class="notification-form">
                <h3>发送新通知</h3>
                <form id="notification-form">
                    <div class="form-group">
                        <label for="title">通知标题 *</label>
                        <input type="text" id="title" required maxlength="100" placeholder="输入通知标题" />
                    </div>
                    
                    <div class="form-group">
                        <label for="body">通知内容</label>
                        <textarea id="body" maxlength="200" placeholder="输入通知内容（可选）"></textarea>
                    </div>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label for="url">跳转链接</label>
                            <input type="url" id="url" placeholder="https://example.com/page" />
                        </div>
                        <div class="form-group">
                            <label for="icon">图标 URL</label>
                            <input type="url" id="icon" placeholder="/favicon.png" value="/favicon.png" />
                        </div>
                    </div>
                    
                    <button type="submit" class="btn btn-primary" id="send-btn">
                        发送通知
                    </button>
                </form>
                <div id="form-message"></div>
            </div>
            
            <!-- 通知历史 -->
            <h3>发送历史</h3>
            <div class="notification-list">
                {notifications.results.length === 0 ? (
                    <div class="empty-state">暂无发送记录</div>
                ) : (
                    notifications.results.map((n) => (
                        <div class="notification-item">
                            <div class="notification-header">
                                <span class="notification-title">{n.title}</span>
                                <span class="notification-time">
                                    {new Date(n.sent_at).toLocaleString('zh-CN')}
                                </span>
                            </div>
                            {n.body && <div class="notification-body">{n.body}</div>}
                            <div class="notification-stats">
                                <span class="success">✓ 成功 {n.delivered_count}</span>
                                {n.failed_count > 0 && <span class="error">✗ 失败 {n.failed_count}</span>}
                                <span>发送者: {n.sender_name || '未知'}</span>
                            </div>
                        </div>
                    ))
                )}
            </div>
        </main>
    </div>

    <script>
        const form = document.getElementById('notification-form') as HTMLFormElement;
        const sendBtn = document.getElementById('send-btn') as HTMLButtonElement;
        const formMessage = document.getElementById('form-message') as HTMLDivElement;

        function showToast(message: string, type: 'success' | 'error' = 'success') {
            const toast = document.createElement('div');
            toast.className = `toast ${type}`;
            toast.textContent = message;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
        }

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            formMessage.textContent = '';
            formMessage.className = '';
            sendBtn.disabled = true;
            sendBtn.textContent = '发送中...';

            const data = {
                title: (document.getElementById('title') as HTMLInputElement).value.trim(),
                body: (document.getElementById('body') as HTMLTextAreaElement).value.trim() || undefined,
                url: (document.getElementById('url') as HTMLInputElement).value.trim() || undefined,
                icon: (document.getElementById('icon') as HTMLInputElement).value.trim() || '/favicon.png',
            };

            try {
                const response = await fetch('/api/notifications/send', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data),
                });

                const result = await response.json();

                if (response.ok) {
                    showToast(`通知已发送！成功: ${result.success}, 失败: ${result.failed}`);
                    form.reset();
                    // 刷新页面以显示新记录
                    setTimeout(() => window.location.reload(), 1500);
                } else {
                    formMessage.textContent = result.error || '发送失败';
                    formMessage.className = 'error-msg';
                    showToast(result.error || '发送失败', 'error');
                }
            } catch (error) {
                formMessage.textContent = '网络错误，请重试';
                formMessage.className = 'error-msg';
                showToast('网络错误', 'error');
            } finally {
                sendBtn.disabled = false;
                sendBtn.textContent = '发送通知';
            }
        });
    </script>
</body>
</html>

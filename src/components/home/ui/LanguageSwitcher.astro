---
/**
 * 语言切换器组件
 * 提供中英文切换功能
 */

type Locale = 'en' | 'zh';

const defaultLocale: Locale = 'zh';

const locales: Locale[] = ['zh', 'en'];

const localeNames: Record<Locale, string> = {
    zh: '中文',
    en: 'English',
};

interface Props {
    currentLocale?: Locale;
}

const { currentLocale = defaultLocale } = Astro.props;
---

<div
    class="language-switcher"
    data-language-switcher
    role="navigation"
    aria-label="Language selection"
>
    <button 
        class="language-toggle" 
        data-language-toggle
        type="button"
        aria-expanded="false" 
        aria-haspopup="listbox"
        aria-label="Select language"
    >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="2" y1="12" x2="22" y2="12"></line>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
        </svg>
        <span class="current-lang">{localeNames[currentLocale]}</span>
        <svg class="chevron" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
    </button>
    
    <ul class="language-menu" data-language-menu role="listbox" aria-label="Available languages">
        {locales.map((locale: Locale) => (
            <li role="option" aria-selected={locale === currentLocale}>
                <button 
                    class={`language-option ${locale === currentLocale ? 'active' : ''}`}
                    data-language-option
                    data-locale={locale}
                    type="button"
                >
                    {localeNames[locale]}
                </button>
            </li>
        ))}
    </ul>
</div>

<script>
    import { setupLanguageSwitcherLifecycle } from '../../../utils/language-switcher-controller'

    setupLanguageSwitcherLifecycle('[data-language-switcher]')
</script>

<style>
    .language-switcher {
        position: relative;
        display: inline-flex;
    }
    
    .language-toggle {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 0.75rem;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 0.5rem;
        color: var(--sl-color-text);
        font-size: 0.875rem;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    
    .language-toggle:hover {
        background: rgba(255, 255, 255, 0.1);
        border-color: rgba(255, 255, 255, 0.2);
    }
    
    :global([data-theme="light"]) .language-toggle {
        background: rgba(0, 0, 0, 0.03);
        border-color: rgba(0, 0, 0, 0.1);
    }
    
    :global([data-theme="light"]) .language-toggle:hover {
        background: rgba(0, 0, 0, 0.06);
        border-color: rgba(0, 0, 0, 0.15);
    }
    
    .chevron {
        transition: transform 0.2s ease;
    }
    
    .language-toggle[aria-expanded="true"] .chevron {
        transform: rotate(180deg);
    }
    
    .language-menu {
        position: absolute;
        top: calc(100% + 0.5rem);
        right: 0;
        min-width: 120px;
        padding: 0.5rem;
        background: rgba(30, 30, 30, 0.95);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 0.5rem;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        list-style: none;
        margin: 0;
        opacity: 0;
        visibility: hidden;
        transform: translateY(-10px);
        transition: all 0.2s ease;
        z-index: 100;
    }
    
    .language-menu.open {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
    }
    
    :global([data-theme="light"]) .language-menu {
        background: rgba(255, 255, 255, 0.95);
        border-color: rgba(0, 0, 0, 0.1);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    }
    
    .language-menu li {
        margin: 0;
        padding: 0;
    }
    
    .language-option {
        display: block;
        width: 100%;
        padding: 0.5rem 0.75rem;
        background: transparent;
        border: none;
        border-radius: 0.25rem;
        color: var(--sl-color-text);
        font-size: 0.875rem;
        text-align: left;
        cursor: pointer;
        transition: all 0.15s ease;
    }
    
    .language-option:hover {
        background: rgba(255, 255, 255, 0.1);
    }
    
    :global([data-theme="light"]) .language-option:hover {
        background: rgba(0, 0, 0, 0.05);
    }
    
    .language-option.active {
        color: var(--sl-color-accent);
        font-weight: 600;
    }
    
    .language-option-disabled {
        margin: 0;
        padding: 0;
    }
    
    .disabled-text {
        display: block;
        width: 100%;
        padding: 0.5rem 0.75rem;
        color: var(--sl-color-text);
        opacity: 0.5;
        font-size: 0.875rem;
        text-align: left;
        cursor: not-allowed;
    }
</style>

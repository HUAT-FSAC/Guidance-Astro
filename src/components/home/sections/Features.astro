---
import { Icon } from "@astrojs/starlight/components";
---

<div class="feature-grid reveal-upon-scroll" role="navigation" aria-label="部门导航">
    <a href="/2025/感知/" class="feature-card reveal-upon-scroll" style="transition-delay: 0.1s;">
        <Icon name="rocket" size="2rem" color="var(--sl-color-accent)" />
        <div>
            <h3>🤖 算法部</h3>
            <p>感知 · 定位建图 · 规控 · 仿真</p>
        </div>
    </a>
    <a href="/2025/电气/" class="feature-card reveal-upon-scroll" style="transition-delay: 0.2s;">
        <Icon name="seti:bicep" size="2rem" color="var(--sl-color-accent)" />
        <div>
            <h3>⚡ 电气部</h3>
            <p>线束 · 软件 · 硬件 · 电池箱</p>
        </div>
    </a>
    <a href="/2025/机械/" class="feature-card reveal-upon-scroll" style="transition-delay: 0.3s;">
        <Icon name="setting" size="2rem" color="var(--sl-color-accent)" />
        <div>
            <h3>🔧 机械部</h3>
            <p>转向悬架 · 传动 · 车架 · 制动</p>
        </div>
    </a>
    <a href="/2025/项管/" class="feature-card reveal-upon-scroll" style="transition-delay: 0.4s;">
        <Icon name="open-book" size="2rem" color="var(--sl-color-accent)" />
        <div>
            <h3>📋 项管部</h3>
            <p>新媒体 · 营销 · 运营管理</p>
        </div>
    </a>
</div>

<style>
    .feature-grid {
        position: relative;
        z-index: 2;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 2rem;
        margin: 3rem 0;
    }

    .feature-card {
        background: linear-gradient(180deg, var(--fs-bg-elevated) 0%, var(--fs-bg-surface) 100%);
        padding: 2.5rem 2rem;
        border-radius: var(--radius-sm);
        text-decoration: none !important;
        color: var(--sl-color-text) !important;
        transition: transform var(--transition-normal), box-shadow var(--transition-normal), border-color var(--transition-normal);
        border: 1px solid var(--fs-border-subtle);
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        position: relative;
        overflow: hidden;
        box-shadow: var(--card-shadow);
    }

    :global([data-theme='light']) .feature-card {
        background: rgba(255, 255, 255, 0.7);
        border-color: rgba(0, 0, 0, 0.1);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    }

    .feature-card::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 1.5px;
        background: linear-gradient(90deg, transparent, var(--sl-color-accent), transparent);
        opacity: 0;
        transition: opacity var(--transition-normal);
    }

    .feature-card:hover::before {
        opacity: 1;
    }

    .feature-card:hover {
        transform: translateY(-5px) scale(1.02);
        background: linear-gradient(180deg, #1c1c21 0%, var(--fs-bg-surface) 100%);
        border-color: var(--fs-border-focus);
        box-shadow: var(--card-shadow-hover), 0 0 20px var(--fs-accent-glow);
    }

    :global([data-theme='light']) .feature-card:hover {
        background: rgba(255, 255, 255, 1);
        border-color: rgba(0, 0, 0, 0.2);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
    }

    .feature-card h3 {
        margin: 0 !important;
        font-family: 'Space Grotesk', system-ui, sans-serif;
        font-size: 1.5rem;
        font-weight: 800;
        letter-spacing: 0.5px;
        color: #fff;
    }
    
    :global([data-theme='light']) .feature-card h3 {
        color: #000;
    }

    .feature-card p {
        margin: 0 !important;
        font-family: 'Space Grotesk', system-ui, sans-serif;
        font-size: 0.95rem;
        opacity: 0.8;
        line-height: 1.6;
    }

    @media (max-width: 640px) {
        .feature-grid {
            grid-template-columns: 1fr;
            gap: 1.5rem;
            margin: 2rem 0;
        }

        .feature-card {
            padding: 2rem 1.5rem;
        }
    }
</style>

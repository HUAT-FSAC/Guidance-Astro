---
import type { Locale } from '../../../utils/i18n'

interface Props {
    locale?: Locale
}

const { locale = 'zh' } = Astro.props

const content =
    locale === 'en'
        ? {
              title: '🙏 Acknowledgement',
              paragraphs: [
                  'We appreciate the organizers, mentors, sponsors, and every supporter who helps make Formula Student possible for student teams each year.',
                  'With the support of the School of Automotive Engineering, our faculty advisors, and the full team, HUAT FSAC is able to turn concepts into a complete autonomous race-car program.',
                  'Thank you to every team member who commits time, energy, and care to the project. The work is demanding, but it is also what makes the team stronger every season.',
              ],
              quote1: 'Aim Higher, Drive the Future',
              quote2: 'Build People, Build Work, Build Cars',
              signature: 'Thank you for backing HUAT FSAC.',
              closing: 'Thank you',
          }
        : {
              title: '🙏 致谢',
              paragraphs: [
                  '衷心感谢中国汽车工程协会和社会各界人士每年动用大量的人力物力去举办这个赛事，让很多热爱赛车的大学生拥有这个展示才能、相互学习、开拓眼界的平台。同时，感谢中国大学生方程式汽车大赛规则委员会悉心制定完善赛事规则，让整体比赛的过程中有规则可依，有条目可参考。感谢东风商用车等赞助商的支持。',
                  '在湖北汽车工业学院汽车工程师学院的大力支持、相关老师的悉心指导和车队全体队员的共同努力下，FSAC 赛车的设计、加工、制造和调试顺利完成。在这个过程中，我们仔细推敲每一个设计思路，严谨处理每一个数据，用心完成每一个细节。这数百个日日夜夜，是赛车最有力的证明，也是我们心底的那份感恩。',
                  '感谢每一位车队队员积极配合，认真工作，使得东风 HUAT 无人驾驶方程式赛车队的设计报告能够顺利完成。感谢每一位车队队员，放弃假期毅然选择留在车队，他们互相帮助，互相鼓励使得车队更加团结。最后感谢每一个为中国大学生方程式汽车大赛默默付出的人，感谢湖北汽车工业学院各级领导对于车队的关注和支持。',
              ],
              quote1: '力争上游，擎动未来',
              quote2: '做人、做事、做车',
              signature: '谨此，我代表湖北汽车工业学院 HUAT 无人驾驶方程式赛车队所有队员致上最诚挚的谢意。',
              closing: '谢谢你们 ❤️',
          }
---

<section class="acknowledgement">
    <div class="ack-container">
        <h2 class="ack-title">{content.title}</h2>

        <div class="ack-content">
            <p>{content.paragraphs[0]}</p>
            <blockquote class="ack-quote">"{content.quote1}"</blockquote>
            <p>{content.paragraphs[1]}</p>
            <blockquote class="ack-quote">"{content.quote2}"</blockquote>
            <p>{content.paragraphs[2]}</p>

            <div class="ack-signature">
                <p>{content.signature}</p>
                <p class="signature-text">{content.closing}</p>
            </div>
        </div>
    </div>
</section>

<style>
    .acknowledgement {
        position: relative;
        z-index: 2;
        padding: 4rem 0;
        background: rgba(255, 255, 255, 0.02);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 2rem;
        margin: 3rem auto;
        max-width: 1400px;
    }

    :global([data-theme='light']) .acknowledgement {
        background: rgba(255, 255, 255, 0.6);
        border-color: rgba(0, 0, 0, 0.1);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    }

    .ack-container {
        max-width: 900px;
        margin: 0 auto;
        padding: 0 2rem;
    }

    .ack-title {
        font-size: 2rem;
        font-weight: 700;
        text-align: center;
        margin-bottom: 2rem;
        color: var(--sl-color-text);
    }

    .ack-content {
        line-height: 1.9;
        color: var(--sl-color-gray-2);
        font-size: 1.05rem;
    }

    .ack-content p {
        margin-bottom: 1.5rem;
        text-align: justify;
    }

    .ack-quote {
        font-size: 1.5rem;
        font-weight: 700;
        text-align: center;
        color: var(--sl-color-accent);
        margin: 2rem 0;
        padding: 1.5rem 2rem;
        border-left: 4px solid var(--sl-color-accent);
        border-right: 4px solid var(--sl-color-accent);
        background: rgba(255, 255, 255, 0.03);
        border-radius: 1rem;
        font-style: italic;
    }

    .ack-signature {
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        text-align: center;
    }

    .signature-text {
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--sl-color-accent);
        margin-top: 1rem !important;
    }

    @media (max-width: 768px) {
        .acknowledgement {
            padding: 3rem 0;
            margin: 2rem auto;
        }

        .ack-container {
            padding: 0 1.5rem;
        }

        .ack-title {
            font-size: 1.75rem;
        }

        .ack-quote {
            font-size: 1.2rem;
            padding: 1rem;
        }
    }
</style>

---
import { showcaseScenarios } from '../../../data/showcase-lab'

const defaultScenario = showcaseScenarios[0]
---

<section class="showcase-entry home-block">
    <div class="showcase-entry-shell">
        <div class="showcase-entry-content">
            <span class="showcase-entry-kicker">Autonomous Showcase</span>
            <h2 class="showcase-entry-heading">智能驾驶交互实验室</h2>
            <p class="showcase-entry-description">
                用完全本地的数据、SVG 可视化和浏览器状态管理，<br/>
                直观展示无人驾驶赛车从感知到执行器的整条闭环。
            </p>
            <div class="showcase-entry-features">
                <div class="feature-item">
                    <span class="feature-icon">◉</span>
                    <span>多场景预设</span>
                </div>
                <div class="feature-item">
                    <span class="feature-icon">◉</span>
                    <span>实时可视化</span>
                </div>
                <div class="feature-item">
                    <span class="feature-icon">◉</span>
                    <span>离线演示</span>
                </div>
            </div>
            <a href="/showcase-dashboard/" class="showcase-entry-cta">
                <span>进入实验室</span>
                <span class="cta-arrow">→</span>
            </a>
        </div>
        <div class="showcase-entry-preview">
            <div class="preview-card">
                <div class="preview-track">
                    <svg viewBox="0 0 320 180" class="track-svg">
                        <defs>
                            <linearGradient id="preview-gradient" x1="0%" y1="0%" x2="100%" y2="0%">
                                <stop offset="0%" stop-color="#f59e0b"></stop>
                                <stop offset="100%" stop-color="#fb7185"></stop>
                            </linearGradient>
                        </defs>
                        <path class="track-path" d="M 40 140 Q 80 40 160 90 Q 240 140 280 60"></path>
                        <path class="track-progress" d="M 40 140 Q 80 40 160 90 Q 200 115 220 100"></path>
                        <circle class="track-car" cx="220" cy="100" r="8"></circle>
                        <circle class="marker cone" cx="80" cy="80" r="4"></circle>
                        <circle class="marker cone" cx="160" cy="90" r="4"></circle>
                        <circle class="marker gate" cx="240" cy="100" r="4"></circle>
                    </svg>
                </div>
                <div class="preview-info">
                    <span class="preview-scenario">{defaultScenario.name}</span>
                    <span class="preview-tagline">{defaultScenario.tagline}</span>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .showcase-entry {
        max-width: none;
        margin: 0;
        padding: 6rem 2rem;
        background:
            radial-gradient(ellipse 80% 50% at 50% 0%, rgba(245, 158, 11, 0.12), transparent 60%),
            radial-gradient(ellipse 60% 40% at 80% 100%, rgba(251, 113, 133, 0.08), transparent 50%),
            linear-gradient(180deg, rgba(7, 10, 18, 0.98), rgba(9, 12, 20, 0.95));
        border-top: 1px solid rgba(245, 158, 11, 0.15);
    }

    :global([data-theme='light']) .showcase-entry {
        background:
            radial-gradient(ellipse 80% 50% at 50% 0%, rgba(245, 158, 11, 0.08), transparent 60%),
            linear-gradient(180deg, rgba(255, 248, 240, 0.98), rgba(255, 255, 255, 0.96));
        border-color: rgba(224, 113, 38, 0.12);
    }

    .showcase-entry-shell {
        max-width: 1200px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1.2fr;
        gap: 4rem;
        align-items: center;
    }

    .showcase-entry-content {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .showcase-entry-kicker {
        font-size: 0.75rem;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        font-weight: 700;
        color: var(--sl-color-accent, #f59e0b);
    }

    .showcase-entry-heading {
        font-family: 'Space Grotesk', system-ui, sans-serif;
        font-size: clamp(2.5rem, 5vw, 3.5rem);
        font-weight: 700;
        line-height: 1.1;
        margin: 0;
        background: linear-gradient(135deg, #f8fafc, #e2e8f0);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    :global([data-theme='light']) .showcase-entry-heading {
        background: linear-gradient(135deg, #0f172a, #334155);
        -webkit-background-clip: text;
        background-clip: text;
    }

    .showcase-entry-description {
        font-size: 1.1rem;
        line-height: 1.7;
        color: rgba(255, 255, 255, 0.65);
        margin: 0;
    }

    :global([data-theme='light']) .showcase-entry-description {
        color: rgba(15, 23, 42, 0.7);
    }

    .showcase-entry-features {
        display: flex;
        gap: 2rem;
        flex-wrap: wrap;
    }

    .feature-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.9rem;
        color: rgba(255, 255, 255, 0.5);
    }

    :global([data-theme='light']) .feature-item {
        color: rgba(15, 23, 42, 0.6);
    }

    .feature-icon {
        color: var(--sl-color-accent, #f59e0b);
        font-size: 0.6rem;
    }

    .showcase-entry-cta {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1rem 2rem;
        background: linear-gradient(135deg, rgba(245, 158, 11, 0.2), rgba(251, 113, 133, 0.15));
        border: 1px solid rgba(245, 158, 11, 0.5);
        border-radius: 999px;
        color: #f59e0b;
        font-weight: 700;
        font-size: 1rem;
        text-decoration: none;
        transition: all 0.25s ease;
        width: fit-content;
    }

    .showcase-entry-cta:hover {
        background: linear-gradient(135deg, rgba(245, 158, 11, 0.3), rgba(251, 113, 133, 0.25));
        transform: translateX(4px);
        box-shadow: 0 8px 24px rgba(245, 158, 11, 0.2);
    }

    .cta-arrow {
        transition: transform 0.25s ease;
    }

    .showcase-entry-cta:hover .cta-arrow {
        transform: translateX(4px);
    }

    .showcase-entry-preview {
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .preview-card {
        width: 100%;
        max-width: 400px;
        background: linear-gradient(180deg, rgba(14, 18, 28, 0.9), rgba(9, 12, 20, 0.85));
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 1.5rem;
        overflow: hidden;
        box-shadow: 0 24px 48px rgba(0, 0, 0, 0.3);
    }

    :global([data-theme='light']) .preview-card {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(252, 250, 248, 0.95));
        border-color: rgba(15, 23, 42, 0.08);
        box-shadow: 0 24px 48px rgba(15, 23, 42, 0.12);
    }

    .preview-track {
        padding: 1.5rem;
        background: rgba(0, 0, 0, 0.2);
    }

    :global([data-theme='light']) .preview-track {
        background: rgba(15, 23, 42, 0.03);
    }

    .track-svg {
        width: 100%;
        height: auto;
    }

    .track-path {
        fill: none;
        stroke: rgba(148, 163, 184, 0.3);
        stroke-width: 16;
        stroke-linecap: round;
        stroke-linejoin: round;
    }

    .track-progress {
        fill: none;
        stroke: url(#preview-gradient);
        stroke-width: 8;
        stroke-linecap: round;
        stroke-linejoin: round;
    }

    .track-car {
        fill: #f8fafc;
        stroke: #fb7185;
        stroke-width: 2.5;
    }

    .marker {
        stroke: rgba(15, 23, 42, 0.6);
        stroke-width: 1.5;
    }

    .marker.cone { fill: #f59e0b; }
    .marker.gate { fill: #38bdf8; }

    .preview-info {
        padding: 1.25rem 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .preview-scenario {
        font-family: 'Space Grotesk', system-ui, sans-serif;
        font-size: 1.1rem;
        font-weight: 600;
    }

    .preview-tagline {
        font-size: 0.85rem;
        color: rgba(255, 255, 255, 0.5);
    }

    :global([data-theme='light']) .preview-tagline {
        color: rgba(15, 23, 42, 0.6);
    }

    @media (max-width: 900px) {
        .showcase-entry-shell {
            grid-template-columns: 1fr;
            gap: 3rem;
            text-align: center;
        }

        .showcase-entry-content {
            align-items: center;
        }

        .showcase-entry-features {
            justify-content: center;
        }
    }

    @media (max-width: 600px) {
        .showcase-entry {
            padding: 4rem 1.25rem;
        }

        .showcase-entry-features {
            flex-direction: column;
            gap: 0.75rem;
            align-items: center;
        }
    }
</style>
---
// 招新入口组件
---

<section class="recruitment-section reveal-upon-scroll">
    <div class="recruitment-container">
        <div class="recruitment-content reveal-upon-scroll" style="transition-delay: 0.1s;">
            <span class="badge">🎯 2025 招新</span>
            <h2>加入我们的车队</h2>
            <p>
                我们正在寻找充满热情的工程学子！无论你是算法爱好者、硬件极客、机械迷还是创意达人，
                这里都有属于你的舞台。与我们一起设计、制造并驾驶无人驾驶方程式赛车！
            </p>
            <div class="departments">
                <span class="dept">🤖 算法部</span>
                <span class="dept">⚡ 电气部</span>
                <span class="dept">🔧 机械部</span>
                <span class="dept">📋 项管部</span>
            </div>
            <a href="/join/" class="cta-button">
                立即报名
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                >
                    <path d="M5 12h14M12 5l7 7-7 7"></path>
                </svg>
            </a>
        </div>
        <div class="recruitment-visual reveal-upon-scroll" style="transition-delay: 0.3s;">
            <div class="icon-grid">
                <div class="icon-item">🏎️</div>
                <div class="icon-item">💻</div>
                <div class="icon-item">🔩</div>
                <div class="icon-item">🏆</div>
            </div>
        </div>
    </div>
</section>

<style>
    .recruitment-section {
        position: relative;
        z-index: 2;
        padding: 4rem 2rem;
        background-color: var(--fs-bg-elevated);
        border-top: 1px solid var(--fs-border-subtle);
        border-bottom: 1px solid var(--fs-border-subtle);
    }

    :global([data-theme='light']) .recruitment-section {
        background-color: #f8f9fa;
        border-color: rgba(0,0,0,0.05);
    }

    .recruitment-container {
        max-width: 1400px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 4rem;
        align-items: center;
    }

    .badge {
        display: inline-block;
        background: var(--sl-color-accent);
        color: var(--fs-bg-base);
        padding: 0.4rem 1rem;
        font-family: 'Space Grotesk', system-ui, sans-serif;
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 1px;
        margin-bottom: 1.5rem;
        text-transform: uppercase;
        clip-path: polygon(10px 0, 100% 0, 100% calc(100% - 10px), calc(100% - 10px) 100%, 0 100%, 0 10px);
    }

    .recruitment-content h2 {
        font-family: 'Space Grotesk', system-ui, sans-serif;
        font-size: clamp(2.5rem, 5vw, 3.5rem);
        font-weight: 900;
        margin: 0 0 1rem 0;
        letter-spacing: -0.02em;
        line-height: 1.1;
        color: #fff;
    }

    :global([data-theme='light']) .recruitment-content h2 {
        color: #000;
    }

    .recruitment-content p {
        font-size: 1.1rem;
        line-height: 1.8;
        color: rgba(255, 255, 255, 0.85);
        margin-bottom: 2rem;
        max-width: 600px;
    }

    :global([data-theme='light']) .recruitment-content p {
        color: rgba(0, 0, 0, 0.7);
    }

    .departments {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-bottom: 2.5rem;
        align-items: center;
    }

    .dept {
        background: rgba(255, 255, 255, 0.05);
        padding: 0.5rem 1rem;
        font-size: 0.9rem;
        font-weight: 600;
        color: #fff;
        border: 1px solid var(--fs-border-focus);
        border-radius: var(--radius-sm);
        height: 36px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        white-space: nowrap;
        box-sizing: border-box;
        transition: background 0.3s ease;
    }
    
    .dept:hover {
        background: rgba(255, 255, 255, 0.1);
        border-color: var(--sl-color-accent);
    }

    :global([data-theme='light']) .dept {
        background: rgba(0, 0, 0, 0.03);
        color: #000;
        border-color: rgba(0, 0, 0, 0.1);
    }

    .cta-button {
        position: relative;
        display: inline-flex;
        align-items: center;
        gap: 0.8rem;
        padding: 1rem 3rem;
        color: #fff !important;
        background: transparent !important;
        border: 1px solid var(--sl-color-accent) !important;
        font-family: 'Space Grotesk', system-ui, sans-serif;
        font-weight: 700;
        font-size: 1rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        text-decoration: none !important;
        transition: all 0.3s var(--fs-ease-out);
        clip-path: polygon(15px 0, 100% 0, 100% calc(100% - 15px), calc(100% - 15px) 100%, 0 100%, 0 15px);
        overflow: hidden;
    }

    :global([data-theme='light']) .cta-button {
        color: var(--sl-color-accent) !important;
    }
    
    .cta-button::before {
        content: '';
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        background: var(--sl-color-accent);
        z-index: -1;
        transform: scaleX(0);
        transform-origin: right;
        transition: transform 0.4s var(--fs-ease-out);
    }

    .cta-button:hover {
        color: #000 !important;
        border-color: transparent !important;
        box-shadow: 0 0 20px var(--fs-accent-glow) !important;
    }
    
    .cta-button:hover::before {
        transform: scaleX(1);
        transform-origin: left;
    }

    .cta-button svg {
        transition: transform var(--transition-normal);
    }

    .cta-button:hover svg {
        transform: translateX(4px);
    }

    .recruitment-visual {
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .icon-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
    }

    .icon-item {
        width: 100px;
        height: 100px;
        background: linear-gradient(180deg, var(--fs-bg-elevated) 0%, var(--fs-bg-surface) 100%);
        border: 1px solid var(--fs-border-subtle);
        border-radius: var(--radius-sm);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
        box-shadow: var(--card-shadow);
        animation: float 6s ease-in-out infinite;
    }

    :global([data-theme='light']) .icon-item {
        background: #ffffff;
        border-color: rgba(0, 0, 0, 0.1);
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
    }

    .icon-item:nth-child(2) {
        animation-delay: 1.5s;
    }
    .icon-item:nth-child(3) {
        animation-delay: 3s;
    }
    .icon-item:nth-child(4) {
        animation-delay: 4.5s;
    }

    .icon-item:hover {
        transform: scale(1.1);
        background: linear-gradient(180deg, #1c1c21 0%, var(--fs-bg-surface) 100%);
        border-color: var(--fs-border-focus);
        box-shadow: var(--card-shadow-hover), 0 0 20px var(--fs-accent-glow);
    }

    :global([data-theme='light']) .icon-item:hover {
        background: rgba(255, 255, 255, 1);
        border-color: rgba(0, 0, 0, 0.15);
    }

    @keyframes float {
        0%,
        100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
    }

    @media (prefers-reduced-motion: reduce) {
        .icon-item { animation: none; }
    }

    @media (max-width: 900px) {
        .recruitment-container {
            grid-template-columns: 1fr;
            gap: 3rem;
        }

        .recruitment-visual {
            order: -1;
        }

        .recruitment-content {
            text-align: center;
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        
        .departments {
            justify-content: center;
        }
    }

    @media (max-width: 600px) {
        .recruitment-section {
            padding: 3rem 1.25rem;
        }

        .recruitment-content h2 {
            font-size: 2rem;
        }

        .cta-button {
            width: 100%;
            justify-content: center;
        }
        
        .icon-grid {
            gap: 1rem;
        }

        .icon-item {
            width: 80px;
            height: 80px;
            font-size: 2rem;
        }
    }
</style>

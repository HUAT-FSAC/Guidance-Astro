---
import { optimizeExternalImage, generateSrcSet, getImageLoadingStrategy, getImageFetchPriority, generateAltText } from "../../../utils/image-optimization";

interface Props {
    badge?: string;
    title: string;
    description: string;
    ctaText: string;
    ctaLink: string;
    image: string;
    reverse?: boolean;
}

const {
    badge,
    title,
    description,
    ctaText,
    ctaLink,
    image,
    reverse = false,
} = Astro.props;

const optimizedImage = optimizeExternalImage(image, 900, 80);
const srcSet = generateSrcSet(image, [450, 675, 900]);
const loading = getImageLoadingStrategy(false);
const fetchPriority = getImageFetchPriority(false);
const altText = generateAltText(title, "成就展示");
---

<section class="achievement-section" role="region" aria-label={title}>
    <div class={`achievement-container ${reverse ? "reverse" : ""}`}>
        <div class="achievement-content reveal-upon-scroll">
            {badge && <span class="achievement-badge">{badge}</span>}
            <h2 class="achievement-title">{title}</h2>
            <p class="achievement-description">{description}</p>
            <a href={ctaLink} class="achievement-cta">
                {ctaText}
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                >
                    <path d="M5 12h14M12 5l7 7-7 7"></path>
                </svg>
            </a>
        </div>
        <div class="achievement-image reveal-upon-scroll" style="transition-delay: 0.15s;">
            <img
                src={optimizedImage}
                srcset={srcSet}
                sizes="(max-width: 900px) 100vw, 50vw"
                alt={altText}
                loading={loading}
                fetchpriority={fetchPriority}
                decoding="async"
            />
        </div>
    </div>
</section>

<style>
    .achievement-section {
        position: relative;
        z-index: 2;
        padding: 6rem 2rem;
        background-color: var(--fs-bg-base);
        background-image: 
            linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
        background-size: 30px 30px;
        margin-bottom: 2rem;
        border-top: 1px solid var(--fs-border-subtle);
        border-bottom: 1px solid var(--fs-border-subtle);
    }

    :global([data-theme="light"]) .achievement-section {
        background-color: #f8f9fa;
        background-image: 
            linear-gradient(rgba(0,0,0,0.02) 1px, transparent 1px),
            linear-gradient(90deg, rgba(0,0,0,0.02) 1px, transparent 1px);
    }

    .achievement-container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: center;
        max-width: 1400px;
        margin: 0 auto;
    }

    .achievement-container.reverse {
        direction: rtl;
    }

    .achievement-container.reverse > * {
        direction: ltr;
    }

    @media (max-width: 900px) {
        .achievement-container {
            grid-template-columns: 1fr;
            gap: 3rem;
        }
        .achievement-section {
            padding: 4rem 1.5rem;
        }
        .achievement-container.reverse {
            direction: ltr;
        }
    }

    @media (max-width: 600px) {
        .achievement-section {
            padding: 3rem 1rem;
        }

        .achievement-title {
            font-size: 2rem !important;
        }

        .achievement-description {
            font-size: 1rem;
        }

        .achievement-cta {
            width: 100%;
            justify-content: center;
        }
    }

    .achievement-content {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .achievement-badge {
        display: inline-flex;
        align-items: center;
        width: fit-content;
        padding: 0.4rem 1rem;
        font-family: 'Space Grotesk', system-ui, sans-serif;
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 1px;
        color: var(--fs-bg-base);
        background: var(--sl-color-accent);
        text-transform: uppercase;
        /* 工程切角 */
        clip-path: polygon(10px 0, 100% 0, 100% calc(100% - 10px), calc(100% - 10px) 100%, 0 100%, 0 10px);
    }

    .achievement-title {
        font-family: 'Space Grotesk', system-ui, sans-serif;
        font-size: clamp(2rem, 4vw, 3rem);
        font-weight: 900;
        line-height: 1.1;
        letter-spacing: -0.02em;
        margin: 0;
        color: #ffffff;
    }

    :global([data-theme="light"]) .achievement-title {
        color: #050505;
    }

    .achievement-description {
        font-size: 1.15rem;
        line-height: 1.8;
        color: rgba(255, 255, 255, 0.85);
        margin: 0;
    }

    :global([data-theme="light"]) .achievement-description {
        color: rgba(0, 0, 0, 0.75);
    }

    .achievement-cta {
        position: relative;
        display: inline-flex;
        align-items: center;
        gap: 0.8rem;
        width: fit-content;
        padding: 1rem 2.5rem;
        font-family: 'Space Grotesk', system-ui, sans-serif;
        font-size: 1rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #fff !important;
        background: transparent;
        border: 1px solid var(--sl-color-accent);
        text-decoration: none;
        transition: all var(--transition-normal);
        clip-path: polygon(15px 0, 100% 0, 100% calc(100% - 15px), calc(100% - 15px) 100%, 0 100%, 0 15px);
        overflow: hidden;
    }

    :global([data-theme="light"]) .achievement-cta {
        color: var(--sl-color-accent) !important;
    }
    
    .achievement-cta::before {
        content: '';
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        background: var(--sl-color-accent);
        z-index: -1;
        transform: scaleX(0);
        transform-origin: right;
        transition: transform 0.4s var(--fs-ease-out);
    }

    .achievement-cta:hover {
        color: #000 !important;
        border-color: transparent !important;
        box-shadow: 0 0 20px var(--fs-accent-glow) !important;
    }

    .achievement-cta:hover::before {
        transform: scaleX(1);
        transform-origin: left;
    }

    .achievement-cta svg {
        transition: transform var(--transition-normal);
    }

    .achievement-cta:hover svg {
        transform: translateX(4px);
    }

    .achievement-image {
        position: relative;
        border-radius: var(--radius-md);
        overflow: hidden;
        aspect-ratio: 16/10;
        box-shadow: var(--card-shadow);
        border: 1px solid var(--fs-border-subtle);
        transition: transform var(--transition-normal), box-shadow var(--transition-normal), border-color var(--transition-normal);
    }
    
    /* 增加高科技照片遮罩角标 */
    .achievement-image::after {
        content: '';
        position: absolute;
        bottom: 0; right: 0;
        width: 30px; height: 30px;
        background: var(--sl-color-accent);
        clip-path: polygon(100% 0, 100% 100%, 0 100%);
    }

    :global([data-theme="light"]) .achievement-image {
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.08);
        border-color: rgba(0, 0, 0, 0.1);
    }

    .achievement-image:hover {
        transform: translateY(-8px);
        box-shadow: var(--card-shadow-hover), 0 0 30px var(--fs-accent-glow);
        border-color: var(--fs-border-focus);
    }

    :global([data-theme="light"]) .achievement-image:hover {
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.15);
    }

    .achievement-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.8s var(--fs-ease-out);
    }

    .achievement-image:hover img {
        transform: scale(1.03);
    }
</style>

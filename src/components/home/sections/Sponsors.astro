---
import type { SponsorGroup, SponsorItem } from "../../../data/home";
import { getImageLoadingStrategy, getImageFetchPriority } from "../../../utils/image-optimization";

interface Props {
    groups: SponsorGroup[];
}

const { groups } = Astro.props;

const loading = getImageLoadingStrategy(false);
const fetchPriority = getImageFetchPriority(false);
---

{
    groups.map((group: SponsorGroup) => (
        <div class="sponsor-section reveal-upon-scroll">
            <h3 class="reveal-upon-scroll" style="transition-delay: 0.1s;">{group.name}</h3>
            <div class="sponsor-grid">
                {group.items.map((sponsor: SponsorItem, index: number) => (
                    <div class="sponsor-card reveal-upon-scroll" style={`transition-delay: ${index * 0.1 + 0.2}s;`}>
                        <div class="sponsor-image-container">
                            <img
                                src={sponsor.logo}
                                alt={sponsor.title}
                                class="sponsor-logo"
                                loading={loading}
                                fetchpriority={fetchPriority}
                                decoding="async"
                            />
                        </div>
                        <span class="sponsor-name">{sponsor.title}</span>
                    </div>
                ))}
            </div>
        </div>
    ))
}

<style>
    .sponsor-section {
        position: relative;
        z-index: 2;
        text-align: center;
        margin: 4rem 0;
    }

    .sponsor-section h3 {
        font-family: 'Space Grotesk', system-ui, sans-serif;
        opacity: 0.9;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        font-size: 1.25rem;
        margin-bottom: 2.5rem;
        color: var(--sl-color-white);
        display: inline-block;
        border-bottom: 2px solid var(--sl-color-accent);
        padding-bottom: 0.5rem;
    }
    
    :global([data-theme="light"]) .sponsor-section h3 {
        color: #000;
    }

    .sponsor-grid {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 2rem;
        align-items: flex-start;
    }

    .sponsor-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
        width: 160px;
        transition: transform var(--transition-normal);
        position: relative;
    }
    
    .sponsor-card:hover {
        transform: translateY(-5px);
    }

    .sponsor-image-container {
        width: 100%;
        height: 100px;
        background: #ffffff;
        border-radius: var(--radius-sm);
        padding: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: var(--card-shadow);
        border: 1px solid var(--fs-border-subtle);
        transition: all var(--transition-normal);
        position: relative;
        overflow: hidden;
    }

    /* 适配浅色模式 */
    :global([data-theme="light"]) .sponsor-image-container {
        background: #ffffff;
        border: 1px solid rgba(0, 0, 0, 0.05);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    }

    .sponsor-logo {
        max-width: 100%;
        max-height: 100%;
        width: auto;
        height: auto;
        object-fit: contain;
        filter: none;
        opacity: 1;
        transition: transform var(--transition-fast);
    }

    .sponsor-name {
        font-size: 0.9rem;
        color: rgba(255, 255, 255, 0.7);
        font-weight: 600;
        line-height: 1.3;
        text-align: center;
        transition: color var(--transition-fast);
        font-family: 'Space Grotesk', system-ui, sans-serif;
    }
    
    :global([data-theme="light"]) .sponsor-name {
        color: rgba(0, 0, 0, 0.6);
    }

    .sponsor-card:hover .sponsor-image-container {
        box-shadow: var(--card-shadow-hover), 0 0 20px var(--fs-accent-glow);
        border-color: var(--sl-color-accent);
    }
    
    .sponsor-card:hover .sponsor-logo {
        transform: scale(1.05);
    }
    
    .sponsor-card:hover .sponsor-name {
        color: var(--sl-color-white);
    }
    
    :global([data-theme="light"]) .sponsor-card:hover .sponsor-name {
        color: var(--sl-color-accent);
    }

    @media (max-width: 768px) {
        .sponsor-grid {
            gap: 1.5rem;
        }

        .sponsor-card {
            width: 130px;
        }

        .sponsor-image-container {
            height: 80px;
            padding: 10px;
        }
        
        .sponsor-name {
            font-size: 0.85rem;
        }
    }
</style>

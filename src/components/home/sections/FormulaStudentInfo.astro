---
interface Props {
    title: string;
    subtitle: string;
    description: string;
    ctaText: string;
    ctaLink: string;
    backgroundImage?: string;
}

const { title, subtitle, description, ctaText, ctaLink, backgroundImage } =
    Astro.props;
---

<section class="fs-section reveal-upon-scroll">
    <div class="fs-background" data-parallax data-parallax-speed="0.2"></div>
    <div class="fs-content reveal-upon-scroll" style="transition-delay: 0.1s;">
        <span class="fs-label">{subtitle}</span>
        <h2 class="fs-title">{title}</h2>
        <p class="fs-description">{description}</p>
        <a href={ctaLink} class="fs-cta">
            {ctaText || "了解更多"}
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
            >
                <path d="M5 12h14M12 5l7 7-7 7"></path>
            </svg>
        </a>
    </div>
</section>

<style
    define:vars={{
        backgroundImage: backgroundImage ? `url(${backgroundImage})` : "none",
    }}
>
    .fs-section {
        position: relative;
        padding: 8rem 2rem;
        text-align: center;
        overflow: hidden;
        border-top: 1px solid var(--fs-border-subtle);
        border-bottom: 1px solid var(--fs-border-subtle);
        background-color: var(--fs-bg-base);
    }

    .fs-background {
        position: absolute;
        inset: 0;
        background: var(--backgroundImage) center/cover no-repeat;
        /* 深色叠加层让背景图片不那么突兀 */
        background-color: rgba(3, 3, 3, 0.85);
        background-blend-mode: overlay;
        opacity: 0.4;
        filter: blur(4px) grayscale(50%);
    }

    .fs-content {
        position: relative;
        z-index: 1;
        max-width: 800px;
        margin: 0 auto;
        background: linear-gradient(180deg, rgba(21, 21, 24, 0.85) 0%, rgba(10, 10, 12, 0.95) 100%);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border-radius: var(--radius-sm);
        padding: 4rem 3rem;
        padding-top: calc(4rem + 2px);
        box-shadow: 0 20px 50px rgba(0,0,0,0.5), inset 0 0 0 1px rgba(255,255,255,0.05);
        /* 工程切角 */
        clip-path: polygon(30px 0, 100% 0, 100% calc(100% - 30px), calc(100% - 30px) 100%, 0 100%, 0 30px);
    }
    
    .fs-content::before {
        content: '';
        position: absolute;
        top: -2px; left: 0; right: 0;
        height: 2px;
        background: linear-gradient(90deg, transparent, var(--sl-color-accent), transparent);
        clip-path: polygon(30px 0, 100% 0, 100% 100%, 0 100%, 0 0);
    }
    
    .fs-content::after {
        content: '';
        position: absolute;
        inset: 0;
        border: 1px solid var(--fs-border-focus);
        clip-path: polygon(30px 0, 100% 0, 100% calc(100% - 30px), calc(100% - 30px) 100%, 0 100%, 0 30px);
        pointer-events: none;
    }

    :global([data-theme='light']) .fs-content {
        background: rgba(255, 255, 255, 0.9);
        border-color: rgba(0, 0, 0, 0.1);
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.1);
    }

    .fs-label {
        font-family: 'Space Grotesk', system-ui, sans-serif;
        display: inline-block;
        font-size: 0.85rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 4px;
        color: var(--sl-color-accent);
        margin-bottom: 1.5rem;
    }

    .fs-title {
        font-family: 'Space Grotesk', system-ui, sans-serif;
        font-size: clamp(2.5rem, 5vw, 4rem);
        font-weight: 900;
        line-height: 1.1;
        letter-spacing: -0.02em;
        margin: 0 0 1.5rem;
        color: #fff;
    }
    
    :global([data-theme='light']) .fs-title {
        color: #000;
    }

    .fs-description {
        font-size: 1.15rem;
        line-height: 1.8;
        color: rgba(255, 255, 255, 0.85);
        margin: 0 0 3rem;
    }
    
    :global([data-theme='light']) .fs-description {
        color: rgba(0, 0, 0, 0.75);
    }

    .fs-cta {
        position: relative;
        display: inline-flex;
        align-items: center;
        gap: 0.8rem;
        padding: 1.2rem 3rem;
        color: #fff !important;
        background: transparent !important;
        font-family: 'Space Grotesk', system-ui, sans-serif;
        font-weight: 700;
        font-size: 1rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        text-decoration: none !important;
        transition: all 0.3s var(--fs-ease-out);
        clip-path: polygon(15px 0, 100% 0, 100% calc(100% - 15px), calc(100% - 15px) 100%, 0 100%, 0 15px);
        overflow: visible;
    }

    :global([data-theme='light']) .fs-cta {
        color: var(--sl-color-accent) !important;
    }
    
    /* 边框伪元素 */
    .fs-cta::after {
        content: '';
        position: absolute;
        inset: 0;
        border: 1px solid var(--sl-color-accent);
        clip-path: polygon(15px 0, 100% 0, 100% calc(100% - 15px), calc(100% - 15px) 100%, 0 100%, 0 15px);
        pointer-events: none;
        transition: all 0.3s var(--fs-ease-out);
    }
    
    .fs-cta::before {
        content: '';
        position: absolute;
        inset: 1px;
        background: var(--sl-color-accent);
        z-index: -1;
        transform: scaleX(0);
        transform-origin: right;
        transition: transform 0.4s var(--fs-ease-out);
        clip-path: polygon(calc(15px - 1px) 0, 100% 0, 100% calc(100% - calc(15px - 1px)), calc(100% - calc(15px - 1px)) 100%, 0 100%, 0 calc(15px - 1px));
    }

    .fs-cta:hover {
        color: #000 !important;
        box-shadow: 0 0 20px var(--fs-accent-glow) !important;
    }
    
    .fs-cta:hover::after {
        border-color: transparent;
    }
    
    .fs-cta:hover::before {
        transform: scaleX(1);
        transform-origin: left;
    }

    .fs-cta svg {
        transition: transform var(--transition-normal);
    }

    .fs-cta:hover svg {
        transform: translateX(4px);
    }

    @media (max-width: 768px) {
        .fs-section {
            padding: 4rem 1.5rem;
        }

        .fs-content {
            padding: 2.5rem 1.5rem;
            clip-path: polygon(20px 0, 100% 0, 100% calc(100% - 20px), calc(100% - 20px) 100%, 0 100%, 0 20px);
        }

        .fs-title {
            font-size: 2.2rem;
        }
    }
</style>

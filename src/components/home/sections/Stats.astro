---
import type { StatItem } from "../../../data/home";

interface Props {
    stats: StatItem[];
}

const { stats } = Astro.props;

// 解析数值和后缀（如 "50+" -> { num: 50, suffix: "+" }）
function parseValue(value: string) {
    const match = value.match(/^(\d+)(.*)$/);
    if (match) {
        return { num: parseInt(match[1]), suffix: match[2] || "" };
    }
    return { num: 0, suffix: value };
}
---

<div class="stats-bar reveal-upon-scroll">
    {
        stats.map((stat, index) => {
            const { num, suffix } = parseValue(stat.value);
            return (
                <div class="stat-item reveal-upon-scroll" style={`transition-delay: ${index * 0.15 + 0.1}s;`}>
                    <div class="value" data-target={num} data-suffix={suffix}>
                        0{suffix}
                    </div>
                    <div class="label">{stat.label}</div>
                </div>
            );
        })
    }
</div>

<script>
    let _statsCountersCleanup: (() => void) | undefined;

    // 数字计数动画
    function animateCounters() {
        const counters = document.querySelectorAll(
            ".stat-item .value[data-target]",
        );

        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        const el = entry.target as HTMLElement;

                        // 防止重复动画
                        if (el.dataset.animated) return;
                        el.dataset.animated = "true";

                        const target = parseInt(el.dataset.target || "0");
                        const suffix = el.dataset.suffix || "";
                        const duration = 2000; // 动画时长 2 秒
                        const startTime = performance.now();

                        function updateCounter(currentTime: number) {
                            const elapsed = currentTime - startTime;
                            const progress = Math.min(elapsed / duration, 1);

                            // 使用 easeOutExpo 缓动函数，让动画更有质感
                            const easeProgress = 1 - Math.pow(1 - progress, 4);
                            const current = Math.floor(easeProgress * target);

                            el.textContent = current + suffix;

                            if (progress < 1) {
                                requestAnimationFrame(updateCounter);
                            } else {
                                el.textContent = target + suffix;
                            }
                        }

                        requestAnimationFrame(updateCounter);
                        observer.unobserve(el);
                    }
                });
            },
            { threshold: 0.1 },
        );

        counters.forEach((counter) => observer.observe(counter));

        return () => observer.disconnect();
    }

    // 等待 PageLoader 消失后再启动动画
    function initCounters() {
        if (_statsCountersCleanup) {
            _statsCountersCleanup();
            _statsCountersCleanup = undefined;
        }

        const loader = document.getElementById("pageLoader");
        // 检查 loader 是否存在且正在显示（没有 loaded 类且 display 不是 none）
        const isLoaderActive =
            loader &&
            !loader.classList.contains("loaded") &&
            loader.style.display !== "none";

        if (isLoaderActive) {
            let started = false;
            let observerCleanup: (() => void) | undefined;
            const startCounters = () => {
                if (started) return;
                started = true;
                observerCleanup = animateCounters();
            };

            // PageLoader 还在显示，等待它消失
            window.addEventListener("pageLoaderHidden", startCounters, {
                once: true,
            });

            // 保底策略：如果事件没有触发，3秒后强制启动
            const fallbackTimer = window.setTimeout(startCounters, 3000);

            _statsCountersCleanup = () => {
                window.clearTimeout(fallbackTimer);
                window.removeEventListener("pageLoaderHidden", startCounters);
                observerCleanup?.();
            };
        } else {
            // PageLoader 已消失或不存在，直接启动
            const observerCleanup = animateCounters();
            _statsCountersCleanup = () => observerCleanup();
        }
    }

    // 增强的初始化逻辑：处理各种加载状态
    if (
        document.readyState === "complete" ||
        document.readyState === "interactive"
    ) {
        initCounters();
    } else {
        document.addEventListener("DOMContentLoaded", initCounters);
    }

    // 兼容 View Transitions
    document.addEventListener("astro:page-load", initCounters);
</script>

<style>
    .stats-bar {
        position: relative;
        z-index: 2;
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 1.5rem;
        padding: 4rem 2rem;
        max-width: 1400px;
        margin: 0 auto 4rem;
        border-bottom: 1px solid var(--fs-border-subtle);
        text-align: center;
    }

    .stat-item {
        flex: 1;
        min-width: 250px;
        max-width: 350px;
        padding: 2.5rem 2rem;
        border-radius: var(--radius-sm);
        background: linear-gradient(180deg, var(--fs-bg-elevated) 0%, var(--fs-bg-surface) 100%);
        border: 1px solid var(--fs-border-subtle);
        transition: transform var(--transition-normal), box-shadow var(--transition-normal), border-color var(--transition-normal);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        box-shadow: var(--card-shadow);
        position: relative;
    }
    
    .stat-item::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--sl-color-accent), transparent);
        opacity: 0;
        transition: opacity var(--transition-normal);
    }

    :global([data-theme="light"]) .stat-item {
        background: rgba(255, 255, 255, 0.8);
        border-color: rgba(0, 0, 0, 0.1);
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
    }

    .stat-item:hover {
        transform: translateY(-5px);
        background: linear-gradient(180deg, #1c1c21 0%, var(--fs-bg-surface) 100%);
        border-color: var(--fs-border-focus);
        box-shadow: var(--card-shadow-hover), 0 0 20px var(--fs-accent-glow);
    }
    
    .stat-item:hover::before {
        opacity: 1;
    }

    :global([data-theme="light"]) .stat-item:hover {
        background: #ffffff;
        border-color: rgba(0, 0, 0, 0.2);
    }

    .stat-item .value {
        font-family: 'Space Grotesk', monospace;
        font-size: 4rem;
        font-weight: 800;
        line-height: 1;
        color: #ffffff;
        text-shadow: 0 0 15px var(--fs-accent-glow);
        margin-bottom: 0.5rem;
        letter-spacing: -0.04em;
    }

    :global([data-theme="light"]) .stat-item .value {
        color: #000;
        text-shadow: none;
    }

    .stat-item .label {
        font-family: 'Space Grotesk', system-ui, sans-serif;
        font-size: 0.85rem;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--sl-color-accent);
    }

    @media (max-width: 768px) {
        .stats-bar {
            padding: 3rem 1rem;
            gap: 1.5rem;
        }
        
        .stat-item {
            min-width: 100%;
            padding: 2rem 1.5rem;
        }

        .stat-item .value {
            font-size: 3rem;
        }
    }
</style>

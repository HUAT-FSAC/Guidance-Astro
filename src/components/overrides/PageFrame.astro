---
/**
 * 自定义文档页面框架
 * 在所有文档页面中添加全局组件（灯箱、悬浮按钮等）
 * 【临时禁用】导航栏登录状态显示 - 复试后再启用
 */
import Default from "@astrojs/starlight/components/PageFrame.astro";
import ImageLightbox from "../docs/ImageLightbox.astro";
import DocFloatingActions from "../docs/DocFloatingActions.astro";
import SearchHint from "../home/ui/SearchHint.astro";
import ErrorBoundary from "../ErrorBoundary.astro";

const isHomePage = Astro.url.pathname === '/' || Astro.url.pathname === '';
const isDocsPage = Astro.url.pathname.startsWith('/docs/') || Astro.url.pathname.startsWith('/en/docs/');
---

<ErrorBoundary>
    <Default>
        <slot name="header" slot="header" />
        <slot name="sidebar" slot="sidebar" />
        <slot />
    </Default>
</ErrorBoundary>

<!-- 全局文档组件（挂在顶层，避免 stacking context 影响点击事件） -->
<ImageLightbox />
{!isHomePage && <DocFloatingActions />}
{isDocsPage && <SearchHint />}

<!-- 全局初始化脚本 -->
<script>
    import('../../utils/global-init')
</script>

---
/**
 * 分享按钮组件
 * 提供浮动分享菜单，支持多平台分享
 * 
 * @example
 * ```astro
 * <ShareButton position="bottom-right" />
 * ```
 */

interface Props {
    /** 按钮位置 */
    position?: 'bottom-right' | 'bottom-left' | 'top-right' | 'top-left';
    /** 是否显示标签 */
    showLabel?: boolean;
}

const { position = 'bottom-right', showLabel = false } = Astro.props;
---

<div class={`share-container ${position}`} data-share-container data-share-button>
    <!-- 主分享按钮 -->
    <button 
        class="share-button" 
        data-share-toggle
        aria-label="分享此页面"
        aria-expanded="false"
    >
        <span class="share-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="18" cy="5" r="3"></circle>
                <circle cx="6" cy="12" r="3"></circle>
                <circle cx="18" cy="19" r="3"></circle>
                <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
                <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
            </svg>
        </span>
        {showLabel && <span class="share-label">分享</span>}
    </button>

    <!-- 分享菜单 -->
    <div class="share-menu" data-share-menu role="menu" aria-label="分享选项">
        <!-- 复制链接 -->
        <button class="share-option" data-share-action="copy" role="menuitem">
            <span class="option-icon">📋</span>
            <span class="option-label">复制链接</span>
        </button>

        <!-- 原生分享 (如果支持) -->
        <button class="share-option native-share" data-share-action="native" role="menuitem" style="display: none;">
            <span class="option-icon">📤</span>
            <span class="option-label">更多分享</span>
        </button>

        <div class="share-divider"></div>

        <!-- Twitter -->
        <button class="share-option" data-share-action="twitter" role="menuitem">
            <span class="option-icon twitter">𝕏</span>
            <span class="option-label">Twitter</span>
        </button>

        <!-- 微博 -->
        <button class="share-option" data-share-action="weibo" role="menuitem">
            <span class="option-icon weibo">🔴</span>
            <span class="option-label">微博</span>
        </button>

        <!-- 微信二维码 -->
        <button class="share-option" data-share-action="wechat" role="menuitem">
            <span class="option-icon wechat">💬</span>
            <span class="option-label">微信</span>
        </button>

        <!-- Telegram -->
        <button class="share-option" data-share-action="telegram" role="menuitem">
            <span class="option-icon telegram">✈️</span>
            <span class="option-label">Telegram</span>
        </button>

        <!-- 邮件 -->
        <button class="share-option" data-share-action="email" role="menuitem">
            <span class="option-icon email">📧</span>
            <span class="option-label">邮件</span>
        </button>
    </div>

    <!-- 微信二维码弹窗 -->
    <div class="qrcode-modal" data-share-modal role="dialog" aria-modal="true" aria-label="微信扫码分享">
        <div class="qrcode-content">
            <h3>微信扫码分享</h3>
            <div class="qrcode-image">
                <img data-share-image src="" alt="微信分享二维码" />
            </div>
            <p class="qrcode-hint">打开微信扫一扫，分享给朋友</p>
            <button class="qrcode-close" type="button" data-share-close>关闭</button>
        </div>
    </div>

    <!-- Toast 提示 -->
    <div class="share-toast" data-share-toast role="alert" aria-live="polite"></div>
</div>

<script>
    import { setupShareMenuLifecycle } from '../../utils/share-controller'

    setupShareMenuLifecycle('[data-share-button]', {
        toggleSelector: '[data-share-toggle]',
        menuSelector: '[data-share-menu]',
        toastSelector: '[data-share-toast]',
        modalSelector: '[data-share-modal]',
        modalImageSelector: '[data-share-image]',
        modalCloseSelector: '[data-share-close]',
    })
</script>

<style>
    .share-container {
        position: fixed;
        z-index: 1000;
    }

    .share-container.bottom-right {
        bottom: 2rem;
        right: 2rem;
    }

    .share-container.bottom-left {
        bottom: 2rem;
        left: 2rem;
    }

    .share-container.top-right {
        top: 5rem;
        right: 2rem;
    }

    .share-container.top-left {
        top: 5rem;
        left: 2rem;
    }

    /* 主分享按钮 */
    .share-button {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        width: 48px;
        height: 48px;
        padding: 0;
        background: var(--sl-color-accent);
        color: #000;
        border: none;
        border-radius: var(--radius-sm);
        cursor: pointer;
        box-shadow: var(--card-shadow);
        transition: all var(--transition-normal);
        position: relative;
        overflow: hidden;
    }

    .share-button:hover {
        transform: scale(1.05);
        box-shadow: var(--card-shadow-hover), 0 0 15px var(--fs-accent-glow);
    }

    .share-icon {
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .share-label {
        font-family: 'Space Grotesk', system-ui, sans-serif;
        font-weight: 700;
        font-size: 0.9rem;
        text-transform: uppercase;
    }

    /* 分享菜单 */
    .share-menu {
        position: absolute;
        bottom: 100%;
        right: 0;
        margin-bottom: 0.75rem;
        background: var(--fs-bg-elevated);
        border: 1px solid var(--fs-border-focus);
        border-radius: var(--radius-md);
        padding: 0.5rem;
        min-width: 160px;
        box-shadow: var(--card-shadow-hover);
        opacity: 0;
        visibility: hidden;
        transform: translateY(10px);
        transition: all var(--transition-fast);
    }

    :global([data-theme="light"]) .share-menu {
        border-color: rgba(0, 0, 0, 0.1);
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
    }

    .share-menu.open {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
    }

    .share-option {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        width: 100%;
        padding: 0.625rem 0.875rem;
        background: transparent;
        border: none;
        border-radius: 0.5rem;
        color: var(--sl-color-text);
        cursor: pointer;
        transition: background 0.2s ease;
        text-align: left;
    }

    .share-option:hover {
        background: rgba(255, 255, 255, 0.1);
    }

    :global([data-theme="light"]) .share-option:hover {
        background: rgba(0, 0, 0, 0.05);
    }

    .option-icon {
        font-size: 1.1rem;
        width: 1.5rem;
        text-align: center;
    }

    .option-label {
        font-size: 0.9rem;
        font-weight: 500;
    }

    .share-divider {
        height: 1px;
        background: rgba(255, 255, 255, 0.1);
        margin: 0.5rem 0;
    }

    :global([data-theme="light"]) .share-divider {
        background: rgba(0, 0, 0, 0.1);
    }

    /* Toast 提示 */
    .share-toast {
        position: fixed;
        bottom: 6rem;
        left: 50%;
        transform: translateX(-50%) translateY(20px);
        background: #333;
        color: #fff;
        padding: 0.75rem 1.5rem;
        border-radius: 0.5rem;
        font-size: 0.9rem;
        font-weight: 500;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s ease;
        z-index: 10001;
    }

    .share-toast.show {
        opacity: 1;
        visibility: visible;
        transform: translateX(-50%) translateY(0);
    }

    .share-toast.success {
        background: #27ae60;
    }

    .share-toast.error {
        background: #e74c3c;
    }

    /* 二维码弹窗 */
    .qrcode-modal {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.8);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 10002;
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s ease;
    }

    .qrcode-modal.show {
        opacity: 1;
        visibility: visible;
    }

    .qrcode-content {
        background: var(--sl-color-bg);
        padding: 2rem;
        border-radius: 1rem;
        text-align: center;
        max-width: 300px;
    }

    .qrcode-content h3 {
        margin: 0 0 1rem 0;
        color: var(--sl-color-text);
    }

    .qrcode-image {
        background: #fff;
        padding: 1rem;
        border-radius: 0.5rem;
        display: inline-block;
    }

    .qrcode-image img {
        display: block;
        width: 200px;
        height: 200px;
    }

    .qrcode-hint {
        margin: 1rem 0;
        color: var(--sl-color-text-gray);
        font-size: 0.9rem;
    }

    .qrcode-close {
        background: var(--sl-color-accent);
        color: #000;
        border: none;
        padding: 0.5rem 1.5rem;
        border-radius: 0.5rem;
        font-weight: 600;
        cursor: pointer;
        transition: opacity 0.2s ease;
    }

    .qrcode-close:hover {
        opacity: 0.9;
    }

    /* 响应式 */
    @media (max-width: 768px) {
        .share-container.bottom-right,
        .share-container.bottom-left {
            bottom: 1rem;
        }

        .share-container.bottom-right {
            right: 1rem;
        }

        .share-container.bottom-left {
            left: 1rem;
        }

        .share-button {
            width: 44px;
            height: 44px;
        }
    }
</style>

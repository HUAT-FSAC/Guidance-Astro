---
/**
 * 文档页面浮动操作按钮组
 * 将主题切换和分享按钮统一管理在右下角，避免位置冲突
 */
import type { Locale } from '../../utils/i18n'
import { getTranslations, getLocaleFromPath } from '../../utils/i18n'
import { THEME_COLORS } from '../../utils/theme-controller'

interface Props {
    locale?: Locale
}

const { locale: propLocale } = Astro.props
const locale = propLocale || getLocaleFromPath(Astro.url.pathname)
const t = getTranslations(locale)
const themeNames = THEME_COLORS.map((theme) => t.theme[theme.key as keyof typeof t.theme] || theme.key)
---

<div class="doc-fab-group" id="doc-fab-group">
    <!-- 主题切换按钮 -->
    <div class="fab-item" id="fab-theme-toggle-wrap" data-current-scheme="dark">
        <button 
            class="fab-btn" 
            id="doc-theme-toggle" 
            aria-label={t.theme.switchTheme} 
            title={t.theme.themeHint}
            aria-haspopup="menu"
            aria-expanded="false"
            aria-controls="doc-theme-dropdown"
        >
            <span class="color-indicator"></span>
            <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="5"></circle>
                <line x1="12" y1="1" x2="12" y2="3"></line>
                <line x1="12" y1="21" x2="12" y2="23"></line>
                <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
                <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
                <line x1="1" y1="12" x2="3" y2="12"></line>
                <line x1="21" y1="12" x2="23" y2="12"></line>
                <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
                <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
            </svg>
            <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
        </button>
        
        <div class="theme-dropdown" id="doc-theme-dropdown" aria-hidden="true">
            <div class="dropdown-header">
                <span class="header-icon">🎨</span>
                <span class="header-text">{t.theme.themeColors}</span>
            </div>
            <div class="color-grid">
                {THEME_COLORS.map((theme, index) => (
                    <button
                        class="color-option"
                        type="button"
                        data-color={theme.color}
                        data-accent={theme.accent}
                        title={themeNames[index]}
                        style={`--theme-color: ${theme.color}`}
                    >
                        <span class="color-dot"></span>
                        <span class="color-name">{themeNames[index]}</span>
                        <span class="color-check">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="20 6 9 17 4 12"></polyline>
                            </svg>
                        </span>
                    </button>
                ))}
            </div>
        </div>
    </div>

    <!-- 分享按钮 -->
    <div class="fab-item" data-share-container>
        <button
            class="fab-btn share-button"
            id="share-toggle-btn"
            aria-label="分享此页面"
            aria-expanded="false"
            aria-controls="share-menu"
        >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="18" cy="5" r="3"></circle>
                <circle cx="6" cy="12" r="3"></circle>
                <circle cx="18" cy="19" r="3"></circle>
                <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
                <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
            </svg>
        </button>

        <!-- 分享菜单 - 向左展开 -->
        <div class="share-menu" id="share-menu" role="menu" aria-label={t.common.share}>
            <button class="share-option" data-share-action="copy" role="menuitem">
                <span class="option-icon">📋</span>
                <span class="option-label">{t.docs.social.copy}</span>
            </button>

            <button class="share-option native-share" data-share-action="native" role="menuitem" style="display: none;">
                <span class="option-icon">📤</span>
                <span class="option-label">{t.docs.social.more}</span>
            </button>

            <div class="share-divider"></div>

            <button class="share-option" data-share-action="twitter" role="menuitem">
                <span class="option-icon twitter">𝕏</span>
                <span class="option-label">{t.docs.social.twitter}</span>
            </button>

            <button class="share-option" data-share-action="weibo" role="menuitem">
                <span class="option-icon weibo">🔴</span>
                <span class="option-label">{t.docs.social.weibo}</span>
            </button>

            <button class="share-option" data-share-action="wechat" role="menuitem">
                <span class="option-icon wechat">💬</span>
                <span class="option-label">{t.docs.social.wechat}</span>
            </button>

            <button class="share-option" data-share-action="telegram" role="menuitem">
                <span class="option-icon telegram">✈️</span>
                <span class="option-label">{t.docs.social.telegram}</span>
            </button>

            <button class="share-option" data-share-action="email" role="menuitem">
                <span class="option-icon email">📧</span>
                <span class="option-label">{t.docs.social.email}</span>
            </button>
        </div>

        <!-- 微信二维码弹窗 -->
        <div class="qrcode-modal" id="qrcode-modal" role="dialog" aria-modal="true" aria-labelledby="qrcode-title">
            <div class="qrcode-content">
                <h3 id="qrcode-title">{t.docs.social.qrcodeTitle}</h3>
                <div class="qrcode-image">
                    <img id="qrcode-img" src="" alt={t.docs.social.qrcodeTitle} />
                </div>
                <p class="qrcode-hint">{t.docs.social.qrcodeHint}</p>
                <button class="qrcode-close" id="qrcode-close">{t.common.close}</button>
            </div>
        </div>

        <!-- Toast 提示 -->
        <div class="share-toast" id="share-toast" role="alert" aria-live="polite"></div>
    </div>
</div>

<script>
    import { setupShareMenuLifecycle } from '../../utils/share-controller'
    import { setupThemeControllerLifecycle } from '../../utils/theme-controller'

    setupThemeControllerLifecycle('#fab-theme-toggle-wrap', {
        toggleSelector: '#doc-theme-toggle',
        dropdownSelector: '#doc-theme-dropdown',
        currentSchemeTargetSelector: '#fab-theme-toggle-wrap',
    })
    setupShareMenuLifecycle('[data-share-container]')
</script>

<style>
    /* ── 浮动按钮组容器 ── */
    .doc-fab-group {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        z-index: var(--z-floating, 1000);
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        align-items: center;
    }

    /* ── 每个按钮的相对定位包裹层 ── */
    .fab-item {
        position: relative;
    }

    /* ── 统一按钮样式 ── */
    .fab-btn {
        width: 48px;
        height: 48px;
        border-radius: var(--radius-sm);
        background: linear-gradient(180deg, var(--fs-bg-elevated) 0%, var(--fs-bg-surface) 100%);
        border: 1px solid var(--fs-border-subtle);
        color: var(--sl-color-text, white);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all var(--transition-normal);
        box-shadow: var(--card-shadow);
        position: relative;
        overflow: hidden;
    }

    .color-indicator {
        position: absolute;
        top: 6px;
        right: 6px;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: var(--sl-color-accent, #f39c12);
        box-shadow: 0 1px 4px color-mix(in srgb, var(--sl-color-accent, #f39c12) 40%, transparent);
        border: 1.5px solid rgba(255, 255, 255, 0.3);
        z-index: 10;
    }

    :global([data-theme='light']) .color-indicator {
        border-color: rgba(0, 0, 0, 0.2);
    }

    .theme-dropdown {
        position: absolute;
        bottom: 56px;
        right: 0;
        background: linear-gradient(180deg, rgba(25, 25, 30, 0.98), rgba(15, 15, 20, 0.98));
        backdrop-filter: blur(24px);
        -webkit-backdrop-filter: blur(24px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 16px;
        padding: 12px;
        min-width: 200px;
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        transform: translateY(8px) scale(0.95);
        transform-origin: bottom right;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 
            0 20px 50px rgba(0, 0, 0, 0.5),
            0 0 1px rgba(255, 255, 255, 0.1);
    }

    .theme-dropdown.active {
        opacity: 1;
        visibility: visible;
        pointer-events: auto;
        transform: translateY(0) scale(1);
    }

    :global([data-theme='light']) .theme-dropdown {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(250, 250, 252, 0.98));
        border-color: rgba(0, 0, 0, 0.08);
        box-shadow: 
            0 20px 50px rgba(0, 0, 0, 0.15),
            0 0 1px rgba(0, 0, 0, 0.1);
    }

    .dropdown-header {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px 12px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        margin-bottom: 8px;
    }

    :global([data-theme='light']) .dropdown-header {
        border-bottom-color: rgba(0, 0, 0, 0.06);
    }

    .header-icon {
        font-size: 1rem;
    }

    .header-text {
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: rgba(255, 255, 255, 0.5);
    }

    :global([data-theme='light']) .header-text {
        color: rgba(0, 0, 0, 0.5);
    }

    .color-grid {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .color-option {
        display: flex;
        align-items: center;
        gap: 12px;
        width: 100%;
        padding: 10px 12px;
        background: transparent;
        border: none;
        border-radius: 10px;
        color: rgba(255, 255, 255, 0.9);
        cursor: pointer;
        transition: all 0.2s ease;
        text-align: left;
    }

    :global([data-theme='light']) .color-option {
        color: rgba(0, 0, 0, 0.85);
    }

    .color-option:hover {
        background: rgba(255, 255, 255, 0.08);
    }

    :global([data-theme='light']) .color-option:hover {
        background: rgba(0, 0, 0, 0.05);
    }

    .color-option.active {
        background: rgba(255, 255, 255, 0.12);
    }

    :global([data-theme='light']) .color-option.active {
        background: rgba(0, 0, 0, 0.08);
    }

    .color-dot {
        width: 18px;
        height: 18px;
        border-radius: 50%;
        background: var(--theme-color);
        box-shadow: 0 2px 8px color-mix(in srgb, var(--theme-color) 40%, transparent);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        flex-shrink: 0;
    }

    .color-option:hover .color-dot {
        transform: scale(1.15);
        box-shadow: 0 4px 12px color-mix(in srgb, var(--theme-color) 50%, transparent);
    }

    .color-option.active .color-dot {
        box-shadow: 
            0 2px 8px color-mix(in srgb, var(--theme-color) 40%, transparent),
            0 0 0 3px color-mix(in srgb, var(--theme-color) 30%, transparent);
    }

    .color-name {
        font-size: 0.875rem;
        font-weight: 500;
        flex: 1;
    }

    .color-check {
        opacity: 0;
        transform: scale(0.8);
        transition: all 0.2s ease;
        color: var(--theme-color);
        flex-shrink: 0;
    }

    .color-option.active .color-check {
        opacity: 1;
        transform: scale(1);
    }

    :global([data-theme='light']) .fab-btn {
        background: rgba(255, 255, 255, 0.9);
        color: #111;
        border-color: rgba(0, 0, 0, 0.1);
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
    }

    .fab-btn:hover {
        transform: scale(1.05);
        border-color: var(--fs-border-focus);
        background: linear-gradient(180deg, #1c1c21 0%, var(--fs-bg-surface) 100%);
        box-shadow: var(--card-shadow-hover), 0 0 15px var(--fs-accent-glow);
    }

    :global([data-theme='light']) .fab-btn:hover {
        background: #fff;
        border-color: rgba(0,0,0,0.2);
    }

    /* 分享按钮特殊色 */
    .share-button {
        background: var(--sl-color-accent);
        color: #000;
        border-color: transparent;
    }

    :global([data-theme='light']) .share-button {
        background: var(--sl-color-accent);
        color: #000;
        border-color: transparent;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
    }

    .share-button:hover {
        background: var(--sl-color-accent-high, var(--sl-color-accent));
        border-color: transparent;
        box-shadow: 0 6px 25px color-mix(in srgb, var(--sl-color-accent) 40%, transparent);
    }

    :global([data-theme='light']) .share-button:hover {
        background: var(--sl-color-accent-high, var(--sl-color-accent));
    }

    /* ── 图标显隐 ── */
    .icon-sun,
    .icon-moon {
        position: absolute;
        transition: opacity 0.2s ease;
    }

    .icon-sun {
        opacity: 1;
    }

    .icon-moon {
        display: none;
    }

    #fab-theme-toggle-wrap[data-current-scheme='light'] .icon-sun {
        display: none;
    }

    #fab-theme-toggle-wrap[data-current-scheme='light'] .icon-moon {
        display: block;
    }

    /* ── 分享菜单（向左展开） ── */
    .share-menu {
        position: absolute;
        bottom: 0;
        right: 56px; /* 按钮宽48px + 8px间距 */
        background: var(--fs-bg-elevated);
        border: 1px solid var(--fs-border-focus);
        border-radius: var(--radius-md);
        padding: 0.5rem;
        min-width: 160px;
        box-shadow: var(--card-shadow-hover);
        opacity: 0;
        visibility: hidden;
        transform: translateX(8px);
        transition: all var(--transition-fast);
        white-space: nowrap;
    }

    :global([data-theme='light']) .share-menu {
        border-color: rgba(0, 0, 0, 0.1);
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
    }

    .share-menu.open {
        opacity: 1;
        visibility: visible;
        transform: translateX(0);
    }

    .share-option {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        width: 100%;
        padding: 0.625rem 0.875rem;
        background: transparent;
        border: none;
        border-radius: 0.5rem;
        color: var(--sl-color-text);
        cursor: pointer;
        transition: background 0.2s ease;
        text-align: left;
    }

    .share-option:hover {
        background: rgba(255, 255, 255, 0.1);
    }

    :global([data-theme='light']) .share-option:hover {
        background: rgba(0, 0, 0, 0.05);
    }

    .option-icon {
        font-size: 1.1rem;
        width: 1.5rem;
        text-align: center;
    }

    .option-label {
        font-size: 0.9rem;
        font-weight: 500;
    }

    .share-divider {
        height: 1px;
        background: rgba(255, 255, 255, 0.1);
        margin: 0.5rem 0;
    }

    :global([data-theme='light']) .share-divider {
        background: rgba(0, 0, 0, 0.1);
    }

    /* ── Toast ── */
    .share-toast {
        position: fixed;
        bottom: 6rem;
        left: 50%;
        transform: translateX(-50%) translateY(20px);
        background: #333;
        color: #fff;
        padding: 0.75rem 1.5rem;
        border-radius: 0.5rem;
        font-size: 0.9rem;
        font-weight: 500;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s ease;
        z-index: var(--z-toast, 10001);
    }

    .share-toast.show {
        opacity: 1;
        visibility: visible;
        transform: translateX(-50%) translateY(0);
    }

    .share-toast.success { background: #27ae60; }
    .share-toast.error   { background: #e74c3c; }

    /* ── 二维码弹窗 ── */
    .qrcode-modal {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.8);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: var(--z-modal, 10000);
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s ease;
    }

    .qrcode-modal.show {
        opacity: 1;
        visibility: visible;
    }

    .qrcode-content {
        background: var(--sl-color-bg);
        padding: 2rem;
        border-radius: 1rem;
        text-align: center;
        max-width: 300px;
    }

    .qrcode-content h3 {
        margin: 0 0 1rem 0;
        color: var(--sl-color-text);
    }

    .qrcode-image {
        background: #fff;
        padding: 1rem;
        border-radius: 0.5rem;
        display: inline-block;
    }

    .qrcode-image img {
        display: block;
        width: 200px;
        height: 200px;
    }

    .qrcode-hint {
        margin: 1rem 0;
        color: var(--sl-color-text-gray);
        font-size: 0.9rem;
    }

    .qrcode-close {
        background: var(--sl-color-accent);
        color: #000;
        border: none;
        padding: 0.5rem 1.5rem;
        border-radius: 0.5rem;
        font-weight: 600;
        cursor: pointer;
        transition: opacity 0.2s ease;
    }

    .qrcode-close:hover { opacity: 0.9; }

    /* ── 响应式 ── */
    @media (max-width: 768px) {
        .doc-fab-group {
            bottom: 1rem;
            right: 1rem;
        }

        .fab-btn {
            width: 44px;
            height: 44px;
        }

        .share-menu {
            right: 52px;
        }
    }
</style>

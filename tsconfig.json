{
    "extends": "astro/tsconfigs/strict",
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@assets/*": ["src/assets/*"],
            "@components/*": ["src/components/*"],
            "@utils/*": ["src/utils/*"],
            "@content/*": ["src/content/*"],
            "@data/*": ["src/data/*"],
            "@lib/*": ["src/lib/*"]
        },
        "types": ["@cloudflare/workers-types"],
        "skipLibCheck": true,
        "strictNullChecks": true,
        "noImplicitAny": true
    },
    "include": ["src/**/*", "src/env.d.ts", ".astro/types.d.ts"]
}

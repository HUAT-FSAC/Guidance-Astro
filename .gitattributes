# ==========================================
# Git 行尾换行符配置
# 统一项目中的换行符风格
# ==========================================

# 自动处理行尾换行符
* text=auto

# 源代码文件使用 LF 换行符
*.ts text eol=lf
*.tsx text eol=lf
*.astro text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf

# 配置文件使用 LF 换行符
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini text eol=lf

# 样式文件使用 LF 换行符
*.css text eol=lf
*.scss text eol=lf
*.less text eol=lf

# 文档文件
*.md text eol=lf
*.mdx text eol=lf

# 脚本文件
*.sh text eol=lf
*.bash text eol=lf

# 标记文件
*.html text eol=lf
*.xml text eol=lf
*.svg text eol=lf

# 二进制文件（不参与换行符转换）
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.avif binary

*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary

*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.rar binary
*.7z binary

*.mp4 binary
*.webm binary
*.mp3 binary
*.ogg binary
*.wav binary

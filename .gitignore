# ==========================================
# Astro 项目 .gitignore
# 技术栈: Astro + Cloudflare + pnpm + Vitest + Playwright
# ==========================================

# ------------------------------------------
# 构建产物
# ------------------------------------------
dist/
# Astro 生成的类型文件
.astro/
# TypeScript 构建信息
*.tsbuildinfo

# ------------------------------------------
# 依赖管理
# ------------------------------------------
node_modules/
# pnpm 本地存储 (如使用非默认存储位置)
.pnpm-store/

# ------------------------------------------
# 环境变量与敏感配置
# ------------------------------------------
# 本地环境变量 (生产环境变量应通过 CI/CD 或托管平台设置)
.env
.env.local
.env.*.local
.env.production
# Cloudflare Workers 本地开发变量
.dev.vars
# 其他可能的本地配置
.dev.vars.*

# 示例文件应被跟踪 (取消忽略)
!.env.example
!.dev.vars.example

# ------------------------------------------
# 密钥与证书 (安全关键)
# ------------------------------------------
*.pem
*.key
*.crt
*.cer
*.der
secrets.*
credentials.*
*.secret
*.token
*.password

# ------------------------------------------
# 日志文件
# ------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ------------------------------------------
# 测试与覆盖率
# ------------------------------------------
coverage/
test-results/
# Playwright 特定
playwright-report/
blob-report/
playwright/.cache/

# ------------------------------------------
# 缓存文件
# ------------------------------------------
.eslintcache
.prettiercache
.stylelintcache
.cache/
.parcel-cache/
.vite/
*.tgz
*.tar.gz

# ------------------------------------------
# 编辑器与 IDE
# ------------------------------------------
# VS Code (保留根目录 .vscode 中的共享配置，忽略个人设置)
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/settings.json
!.vscode/tasks.json

# JetBrains IDE
.idea/
*.iml
*.iws
*.ipr
.idea_modules/

# Vim
*.swp
*.swo
*~
.netrwhist

# Sublime Text
*.sublime-project
*.sublime-workspace

# Emacs
*~
\#*\#/
/.emacs.desktop
/.emacs.desktop.lock
*.elc

# ------------------------------------------
# 操作系统生成文件
# ------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
.directory
.Trash-*

# ------------------------------------------
# 临时文件
# ------------------------------------------
.tmp/
.tmp-*
.tmp-dev-*
.tmp-devserver-*
*.tmp
*.temp
*.bak
*.backup
*.orig
*.old

# ------------------------------------------
# 项目特定目录
# ------------------------------------------
# AI/编辑器相关
.claude/
.omc/

# ------------------------------------------
# 部署平台配置 (如使用)
# ------------------------------------------
# Cloudflare (保留 wrangler.toml，忽略本地状态)
.wrangler/
# Vercel (如曾使用)
.vercel
# Netlify (如曾使用)
.netlify

# ------------------------------------------
# 其他
# ------------------------------------------
# 本地开发服务器配置
*.local

# 调试文件
.node_repl_history

# Lighthouse CI reports
.lighthouseci/

